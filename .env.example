# AT Proto service URL (default: public bsky.social)
ATPROTO_SERVICE=https://bsky.social

# AT Proto credentials for scripts (upload + record creation)
ATPROTO_IDENTIFIER=you.bsky.social
ATPROTO_PASSWORD=your-app-password

# Server config
PORT=3000
HOST=127.0.0.1

# Optional: extra browser origins for CORS (comma-separated). By default,
# https://functions.at and https://*.functions.at are allowed.
# ATFUNCTIONS_CORS_ORIGINS=https://staging.functions.at

# Max blob size the server will fetch from AT Proto (bytes, default 5MB)
MAX_BLOB_BYTES=5242880
