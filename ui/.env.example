# Browser-exposed (must start with PUBLIC_). Used at `bun run build` time.
# In GitHub Actions, set the same names as repository Variables (see .github/workflows/docker-and-ui.yml).

# AT Search query-node base URL (no trailing slash). When set, the catalog uses
# GET /search?q=type:at.functions.metadata and search uses your query + collection filter.
PUBLIC_ATSEARCH_URL=http://127.0.0.1:13002

# Optional overrides (defaults match production functions.at)
# PUBLIC_ATP_SERVICE=https://bsky.social
# PUBLIC_AT_FUNCTIONS_API=https://api.functions.at

# Fallback catalog when PUBLIC_ATSEARCH_URL is unset (single-account listRecords)
# PUBLIC_DEFAULT_FUNCTIONS_HANDLE=hamburgerz.bsky.social
